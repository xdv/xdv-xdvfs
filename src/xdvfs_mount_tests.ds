// Description:
//   XDVFS - Mount Tests

forge XdvFsMountTests {

    const TEST_PASS: UInt32 = 0;
    const TEST_FAIL: UInt32 = 1;

    const MOUNT_OK: UInt32 = 0;
    const MOUNT_FAIL: UInt32 = 1;

    proc K::expect_u32(actual: UInt32, expected: UInt32) {
        if actual == expected {
            return TEST_PASS;
        } else {
            return TEST_FAIL;
        }
    }

    proc K::combine(lhs: UInt32, rhs: UInt32) {
        if lhs == TEST_PASS {
            return rhs;
        } else {
            return TEST_FAIL;
        }
    }

    proc K::test_mount_flags() {
        let t1 = expect_u32(is_supported_mount_flags(0), MOUNT_OK);
        let t2 = expect_u32(is_supported_mount_flags(1), MOUNT_OK);
        let t3 = expect_u32(is_supported_mount_flags(2), MOUNT_OK);
        let t4 = expect_u32(is_supported_mount_flags(4), MOUNT_OK);
        let t5 = expect_u32(is_supported_mount_flags(8), MOUNT_OK);
        let t6 = expect_u32(is_supported_mount_flags(16), MOUNT_OK);
        let t7 = expect_u32(is_supported_mount_flags(1 + 2), MOUNT_OK);
        let t8 = expect_u32(is_supported_mount_flags(1 + 8), MOUNT_OK);
        let t9 = expect_u32(is_supported_mount_flags(99), MOUNT_FAIL);

        let u1 = combine(t1, t2);
        let u2 = combine(u1, t3);
        let u3 = combine(u2, t4);
        let u4 = combine(u3, t5);
        let u5 = combine(u4, t6);
        let u6 = combine(u5, t7);
        let u7 = combine(u6, t8);
        return combine(u7, t9);
    }

    proc K::test_required_contracts() {
        let path_ok = validate_required_paths_contract();
        let sb_ok = validate_superblock_contract();
        let alloc_inode_ok = validate_allocator_and_inode_contract();

        let t1 = expect_u32(path_ok, MOUNT_OK);
        let t2 = expect_u32(sb_ok, MOUNT_OK);
        let t3 = expect_u32(alloc_inode_ok, MOUNT_OK);

        let u1 = combine(t1, t2);
        return combine(u1, t3);
    }

    proc K::test_format_fsck_mount_consistency() {
        let status = fsck_format_mount_consistency("xdv0", "/", "xdvfs", 0);
        return expect_u32(status, MOUNT_OK);
    }

    proc K::test_mount_unmount_remount() {
        let mounted = mount("xdv0", "/", "xdvfs", 0);
        let remounted = remount("/", 1);
        let unmounted = unmount("/");

        let t1 = expect_u32(mounted, MOUNT_OK);
        let t2 = expect_u32(remounted, MOUNT_OK);
        let t3 = expect_u32(unmounted, MOUNT_OK);

        let u1 = combine(t1, t2);
        return combine(u1, t3);
    }

    proc K::test_sync_check_format_stats() {
        let sync = sync_filesystem(1);
        let check = check_filesystem("xdv0");
        let format = format_filesystem("xdv0");
        let stats = get_fs_stats(1);

        let t1 = expect_u32(sync, MOUNT_OK);
        let t2 = expect_u32(check, MOUNT_OK);
        let t3 = expect_u32(format, MOUNT_OK);
        if stats == 16384 {
            let u1 = combine(t1, t2);
            return combine(u1, t3);
        } else {
            return TEST_FAIL;
        }
    }

    proc K::run_all_tests() {
        let t1 = test_mount_flags();
        let t2 = combine(t1, test_required_contracts());
        let t3 = combine(t2, test_format_fsck_mount_consistency());
        let t4 = combine(t3, test_mount_unmount_remount());
        return combine(t4, test_sync_check_format_stats());
    }
}
